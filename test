      <!-- Sign-up Panel -->
      <div class="panel" id="signupPanel">
        <div class="field">
          <label for="signupId">User ID</label>
          <div class="input-wrap">
            <input type="text" id="signupId" placeholder="Choose a user ID" autocomplete="username" />
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
          </div>
        </div>
        <div class="field">
          <label for="signupPw">Password</label>
          <div class="input-wrap">
            <input type="password" id="signupPw" placeholder="Create a password" autocomplete="new-password" />
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
        </div>
        <div class="field" style="margin-bottom:0">
          <label for="signupPw2">Confirm Password</label>
          <div class="input-wrap">
            <input type="password" id="signupPw2" placeholder="Re-enter your password" autocomplete="new-password" />
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            </svg>
          </div>
        </div>
        <button class="btn btn-primary" id="signupBtn" onclick="handleSignup()" style="margin-top:18px">
          <div class="spinner"></div>
          <span class="btn-label">Create Account</span>
        </button>
      </div>
    </div>

    <p class="footer">Passwords are encrypted with BCrypt &amp; protected by JWT.</p>
  </section>

  <!-- ── Dashboard (shown after login) ─────────────────────────── -->
  <section id="dashboard">
    <div class="dash-card">
      <div class="dash-header">
        <div class="avatar" id="avatarLetter">?</div>
        <div class="dash-header-text">
          <h2 id="dashUsername">—</h2>
          <p>Welcome back to Smart Study AI</p>
        </div>
      </div>

      <div class="token-badge">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
        </svg>
        JWT token active — session authenticated
      </div>

      <div class="dash-actions">
        <button class="btn btn-ghost" onclick="goToApp()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               style="width:16px;height:16px">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
            <path d="M9 18c-4.51 2-5-2-7-2"/>
          </svg>
          Continue to Study Dashboard
        </button>
        <button class="btn btn-ghost" onclick="handleLogout()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               style="width:16px;height:16px">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
          Sign Out
        </button>
      </div>

      <div class="danger-zone">
        <p>Permanently remove your account and all study data. This cannot be undone.</p>
        <button class="btn btn-danger" onclick="openConfirm()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
               stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
               style="width:15px;height:15px">
            <polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
            <path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
          </svg>
          Delete My Account
        </button>
      </div>
    </div>
  </section>

</div><!-- /.page -->


<script>
/* ═══════════════════════════════════════════════════════════════════
   CONFIG
═══════════════════════════════════════════════════════════════════ */
const API_BASE = '';   // e.g. 'https://api.smartstudy.ai' — leave '' for same-origin
const TOKEN_KEY = 'ss_jwt';
const USER_KEY  = 'ss_user';

/* ═══════════════════════════════════════════════════════════════════
   TOKEN HELPERS
═══════════════════════════════════════════════════════════════════ */
const saveToken  = (token)    => localStorage.setItem(TOKEN_KEY, token);
const getToken   = ()         => localStorage.getItem(TOKEN_KEY);
const clearToken = ()         => { localStorage.removeItem(TOKEN_KEY); localStorage.removeItem(USER_KEY); };
const saveUser   = (userId)   => localStorage.setItem(USER_KEY, userId);
const getUser    = ()         => localStorage.getItem(USER_KEY) || '';

/** Decode JWT payload (no verification — verification is server-side) */
function decodeJwtPayload(token) {
  try {
    const base64 = token.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
    return JSON.parse(atob(base64));
  } catch { return null; }
}

/** Returns true if a valid, non-expired JWT is stored */
function isTokenValid() {
  const token = getToken();
  if (!token) return false;
  const payload = decodeJwtPayload(token);
  if (!payload) return false;
  if (payload.exp && Date.now() / 1000 > payload.exp) {
    clearToken();
    return false;
  }
  return true;
}

/* ═══════════════════════════════════════════════════════════════════
   API LAYER
═══════════════════════════════════════════════════════════════════ */
async function apiRequest(method, path, body = null, requireAuth = false) {
  const headers = { 'Content-Type': 'application/json' };
  if (requireAuth) {
    const token = getToken();
    if (!token) throw new Error('Not authenticated. Please sign in.');
    headers['Authorization'] = `Bearer ${token}`;
  }
  const opts = { method, headers };
  if (body) opts.body = JSON.stringify(body);

  const res = await fetch(`${API_BASE}${path}`, opts);

  // Try to parse JSON; fall back gracefully
  let data;
  const ct = res.headers.get('content-type') || '';
  if (ct.includes('application/json')) {
    data = await res.json();
  } else {
    data = { message: await res.text() };
  }

  if (!res.ok) {
    throw new Error(data.message || data.error || `Server error (${res.status})`);
  }
  return data;
}

/* ═══════════════════════════════════════════════════════════════════
   AUTH HANDLERS
═══════════════════════════════════════════════════════════════════ */

/** Sign up — POST /api/auth/register */
async function handleSignup() {
  const userId   = document.getElementById('signupId').value.trim();
  const password = document.getElementById('signupPw').value;
  const confirm  = document.getElementById('signupPw2').value;

  if (!userId || !password || !confirm) {
    return toast('error', 'Missing fields', 'Please fill in all fields.');
  }
  if (userId.length < 3) {
    return toast('error', 'User ID too short', 'User ID must be at least 3 characters.');
  }
  if (password.length < 6) {
    return toast('error', 'Password too short', 'Password must be at least 6 characters.');
  }
  if (password !== confirm) {
    return toast('error', 'Passwords do not match', 'Please re-enter your password.');
  }

  const btn = document.getElementById('signupBtn');
  setLoading(btn, true);
  try {
    await apiRequest('POST', '/api/auth/register', { userId, password });
    toast('success', 'Account created!', 'You can now sign in with your credentials.');
    document.getElementById('signupId').value  = '';
    document.getElementById('signupPw').value  = '';
    document.getElementById('signupPw2').value = '';
    switchTab('login');
    document.getElementById('loginId').value = userId;
    document.getElementById('loginId').focus();
  } catch (err) {
    toast('error', 'Registration failed', err.message);
  } finally {
    setLoading(btn, false);
  }
}

/** Login — POST /api/auth/login, stores JWT */
async function handleLogin() {
  const userId   = document.getElementById('loginId').value.trim();
  const password = document.getElementById('loginPw').value;

  if (!userId || !password) {
    return toast('error', 'Missing credentials', 'Please enter your user ID and password.');
  }

  const btn = document.getElementById('loginBtn');
  setLoading(btn, true);
  try {
    const data = await apiRequest('POST', '/api/auth/login', { userId, password });
    if (!data.token) throw new Error('No token received from server.');
    saveToken(data.token);
    saveUser(userId);
    toast('success', 'Signed in!', `Welcome back, ${userId}.`);
    document.getElementById('loginPw').value = '';
    showDashboard(userId);
  } catch (err) {
    toast('error', 'Login failed', err.message);
  } finally {
    setLoading(btn, false);
  }
}

/** Logout — clears local token */
function handleLogout() {
  clearToken();
  toast('success', 'Signed out', 'See you next time!');
  showAuth();
}

/** Delete account — DELETE /api/auth/delete with Bearer token */
async function executeDeleteAccount() {
  const btn = document.getElementById('confirmDeleteBtn');
  setLoading(btn, true);
  try {
    await apiRequest('DELETE', '/api/auth/delete', null, true);
    clearToken();
    closeConfirm();
    toast('success', 'Account deleted', 'Your account has been permanently removed.');
    showAuth();
  } catch (err) {
    toast('error', 'Deletion failed', err.message);
  } finally {
    setLoading(btn, false);
  }
}

/** Called when user tries to access a protected page/feature */
function checkAuthGuard() {
  if (!isTokenValid()) {
    toast('error', 'Session expired', 'Please sign in again to continue.');
    clearToken();
    showAuth();
    return false;
  }
  return true;
}

function goToApp() {
  if (!checkAuthGuard()) return;
  // Navigate to the main app. Adjust href as needed.
  toast('success', 'Token valid ✓', 'Navigating to study dashboard…');
  // window.location.href = '/app/dashboard';   ← uncomment when ready
}

/* ═══════════════════════════════════════════════════════════════════
   UI HELPERS
═══════════════════════════════════════════════════════════════════ */
function switchTab(tab) {
  const isLogin = tab === 'login';
  document.getElementById('loginTab').classList.toggle('active', isLogin);
  document.getElementById('signupTab').classList.toggle('active', !isLogin);
  document.getElementById('loginPanel').classList.toggle('active', isLogin);
  document.getElementById('signupPanel').classList.toggle('active', !isLogin);
}

function showDashboard(userId) {
  document.getElementById('authSection').style.display = 'none';
  document.getElementById('dashboard').style.display   = 'block';
  document.getElementById('dashUsername').textContent  = userId;
  document.getElementById('avatarLetter').textContent  = userId.charAt(0).toUpperCase();
}

function showAuth() {
  document.getElementById('authSection').style.display = '';
  document.getElementById('dashboard').style.display   = 'none';
}

function setLoading(btn, on) {
  btn.disabled = on;
  btn.classList.toggle('loading', on);
}

/* confirm dialog */
function openConfirm()  { document.getElementById('confirmOverlay').classList.add('open'); }
function closeConfirm() { document.getElementById('confirmOverlay').classList.remove('open'); }

/* click outside confirm box to close */
document.getElementById('confirmOverlay').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeConfirm();
});

/* ─── Toast notifications ────────────────────────────────────── */
function toast(type, title, message, duration = 4500) {
  const area = document.getElementById('toastArea');
  const icons = {
    success: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
      fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    error:   `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
      fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  };
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<div class="toast-icon">${icons[type] || ''}</div>
    <div class="toast-body"><strong>${title}</strong><p>${message}</p></div>`;
  area.appendChild(el);

  setTimeout(() => {
    el.classList.add('fade-out');
    el.addEventListener('animationend', () => el.remove());
  }, duration);
}

/* ─── Enter-key shortcuts ────────────────────────────────────── */
document.getElementById('loginPw').addEventListener('keydown',  e => { if (e.key === 'Enter') handleLogin(); });
document.getElementById('signupPw2').addEventListener('keydown', e => { if (e.key === 'Enter') handleSignup(); });

/* ═══════════════════════════════════════════════════════════════════
   INIT — restore session if token still valid
═══════════════════════════════════════════════════════════════════ */
(function init() {
  if (isTokenValid()) {
    const userId = getUser();
    showDashboard(userId || 'User');
    toast('success', 'Session restored', `Welcome back, ${userId || 'User'}.`);
  }
})();
</script>
